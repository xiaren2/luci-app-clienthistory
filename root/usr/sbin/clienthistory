#!/usr/bin/env ucode

'use strict';

import {
	readfile, writefile, open, mkdir, rename
} from 'fs';
import { connect } from 'ubus';

const HISTORY_DIR  = '/var/lib/clienthistory';
const HISTORY_FILE = HISTORY_DIR + '/history.json';
const LOCK_FILE    = '/var/lock/clienthistory.lock';
const INTERVAL     = 30;

function load_history() {
	let f = readfile(HISTORY_FILE);
	if (!f) return {};
	try { return json(f) || {}; } catch { return {}; }
}

function save_history(data) {
	let tmp = HISTORY_FILE + '.tmp';
	writefile(tmp, sprintf('%J', data));
	rename(tmp, HISTORY_FILE);
}

function get_ip_neigh() {
	let r = {};
	let fd = open('/proc/net/arp');
	if (!fd) return r;

	while (true) {
		let l = fd.read('line');
		if (!l) break;

		let p = split(l, /\s+/);
		if (length(p) < 6) continue;

		let ip = p[0];
		let mac = lc(p[3]);
		let dev = p[5];

		if (mac == '00:00:00:00:00:00') continue;

		if (!r[mac]) r[mac] = {};
		r[mac].ifname = dev;
		if (index(ip, ':') >= 0)
			r[mac].ipv6 = ip;
		else
			r[mac].ipv4 = ip;
	}
	fd.close();
	return r;
}

function poll_stations() {
	let ubus = connect();
	if (!ubus) return;

	let now = time();
	let hints = ubus.call('luci-rpc', 'getHostHints') || {};
	let history = load_history();

	/* WiFi */
	let ws = ubus.call('network.wireless', 'status') || {};
	for (let radio in ws) {
		for (let iface in ws[radio]?.interfaces || {}) {
			let ifname = iface?.ifname;
			if (!ifname) continue;

			let assoc = ubus.call('iwinfo', 'assoclist', { device: ifname }) || {};
			for (let sta in assoc.results || {}) {
				let mac = lc(sta.mac);
				if (!mac) continue;

				history[mac] = {
					mac,
					type: 'wifi',
					hostname: hints?.[mac]?.name || '',
					ipv4: hints?.[mac]?.ipaddrs?.[0] || '',
					ipv6: hints?.[mac]?.ip6addrs?.[0] || '',
					network: ubus.call('iwinfo', 'info', { device: ifname })?.ssid || ifname,
					ifname,
					connected: true,
					signal: sta.signal || 0,
					first_seen: history[mac]?.first_seen || now,
					last_seen: now
				};
			}
		}
	}

	/* Ethernet */
	let neigh = get_ip_neigh();
	for (let mac in neigh) {
		if (history[mac]?.type == 'wifi') continue;
		if (neigh[mac].ifname == 'eth0' || neigh[mac].ifname == 'wan') continue;

		history[mac] = {
			mac,
			type: 'ethernet',
			hostname: hints?.[mac]?.name || '',
			ipv4: neigh[mac].ipv4 || '',
			ipv6: neigh[mac].ipv6 || '',
			network: 'LAN',
			ifname: neigh[mac].ifname,
			connected: !!(neigh[mac].ipv4),
			signal: 0,
			first_seen: history[mac]?.first_seen || now,
			last_seen: now
		};
	}

	save_history(history);
	ubus.disconnect();
}

mkdir(HISTORY_DIR);
while (true) {
	let lock = open(LOCK_FILE, 'w');
	if (lock && lock.lock('xn')) {
		poll_stations();
		lock.lock('u');
	}
	lock?.close();
	sleep(INTERVAL);
}
