#!/usr/bin/env ucode
'use strict';

import { readfile, writefile, open, mkdir, rename } from 'fs';
import { connect } from 'ubus';

const HISTORY_DIR = '/var/lib/wifihistory';
const HISTORY_FILE = HISTORY_DIR + '/history.json';
const LOCK_FILE = '/var/lock/wifihistory.lock';

function load_history() {
	let content = readfile(HISTORY_FILE);
	if (content == null)
		return {};
	try {
		return json(content) || {};
	} catch (e) {
		return {};
	}
}

function save_history(data) {
	let tmp = HISTORY_FILE + '.tmp';
	writefile(tmp, sprintf('%J', data));
	rename(tmp, HISTORY_FILE);
}

function poll_stations(history, hints, now) {
	let ubus = connect();
	if (!ubus)
		return;

	let wifi_status = ubus.call('network.wireless', 'status');
	if (!wifi_status)
		return;

	for (let radio in wifi_status) {
		let ifaces = wifi_status[radio]?.interfaces;
		if (!ifaces)
			continue;

		for (let iface in ifaces) {
			let ifname = iface?.ifname;
			if (!ifname)
				continue;

			let info = ubus.call('iwinfo', 'info', { device: ifname });
			let ssid = info?.ssid || '';

			let assoc = ubus.call('iwinfo', 'assoclist', { device: ifname });
			if (!assoc?.results)
				continue;

			for (let bss in assoc.results) {
				let mac = uc(bss.mac);
				if (!mac)
					continue;

				let hostname = hints?.[mac]?.name || '';
				let ipv4 = hints?.[mac]?.ipaddrs?.[0] || '';
				let ipv6 = hints?.[mac]?.ip6addrs?.[0] || '';

				history[mac] = {
					mac: mac,
					hostname: hostname,
					ipv4: ipv4,
					ipv6: ipv6,
					network: ssid,
					ifname: ifname,
					type: 'wifi',
					connected: true,
					signal: bss.signal || 0,
					noise: bss.noise || 0,
					first_seen: history[mac]?.first_seen || now,
					last_seen: now
				};
			}
		}
	}

	ubus.disconnect();
}

function poll_wired_clients(history, hints, now) {
	let ubus = connect();
	if (!ubus)
		return;

	let dhcp = ubus.call('dhcp', 'lease_dump') || {};
	for (let mac in dhcp) {
		let e = dhcp[mac];
		if (!e.iface)
			continue;

		if (e.iface ~= /^eth|^br|^lan/) {
			let hostname = hints?.[mac]?.name || e.hostname || '';
			let ip = e.ipaddr || '';

			history[mac] = history[mac] || {
				mac: mac,
				hostname: hostname,
				ipv4: ip,
				network: e.iface,
				ifname: e.iface,
				type: 'wired',
				connected: true,
				first_seen: now,
				last_seen: now
			};
		}
	}

	ubus.disconnect();
}

mkdir(HISTORY_DIR);

let lock_fd = open(LOCK_FILE, 'w');
if (!lock_fd || !lock_fd.lock('xn')) {
	warn('Another instance is already running\n');
	exit(1);
}

let now = time();
let history = load_history();
let hints = connect()?.call('luci-rpc', 'getHostHints') || {};

poll_stations(history, hints, now);
poll_wired_clients(history, hints, now);

save_history(history);

lock_fd.lock('u');
lock_fd.close();
