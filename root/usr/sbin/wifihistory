#!/usr/bin/env ucode

'use strict';

import { readfile, writefile, open, mkdir, rename, popen } from 'fs';
import { connect } from 'ubus';

const HISTORY_DIR = '/var/lib/wifihistory';
const HISTORY_FILE = HISTORY_DIR + '/history.json';
const LOCK_FILE = '/var/lock/wifihistory.lock';

function load_history() {
	let content = readfile(HISTORY_FILE);

	if (content == null)
		return {};

	try {
		return json(content) || {};
	}
	catch (e) {
		return {};
	}
}

function save_history(data) {
	let tmp = HISTORY_FILE + '.tmp';

	writefile(tmp, sprintf('%J', data));
	rename(tmp, HISTORY_FILE);
}

function get_ip_neigh() {
	let result = {};
	let fd = popen('ip neigh');

	if (!fd)
		return result;

	while (true) {
		let line = fd.read('line');

		if (!line)
			break;

		line = trim(line);

		let m = match(line,
			/^([0-9a-fA-F\:\.]+)\s+dev\s+(\S+).*lladdr\s+([0-9a-fA-F\:]+)\s+/);

		if (!m)
			continue;

		let ip = m[1];
		let dev = m[2];
		let mac = uc(m[3]);

		if (!result[mac])
			result[mac] = {};

		if (index(ip, ':') >= 0)
			result[mac].ipv6 = ip;
		else
			result[mac].ipv4 = ip;

		result[mac].ifname = dev;
	}

	fd.close();

	return result;
}

function poll_stations() {
	let ubus = connect();

	if (!ubus) {
		warn('Failed to connect to ubus\n');
		return;
	}

	let now = time();

	let history = load_history();
	let seen_macs = {};

	let hints = ubus.call('luci-rpc', 'getHostHints') || {};

	/*
	 * WIFI CLIENTS
	 */

	let wifi_status = ubus.call('network.wireless', 'status');

	if (wifi_status) {
		for (let radio in wifi_status) {
			let ifaces = wifi_status[radio]?.interfaces;

			if (!ifaces)
				continue;

			for (let iface in ifaces) {
				let ifname = iface?.ifname;

				if (!ifname)
					continue;

				let info = ubus.call('iwinfo', 'info', {
					device: ifname
				});

				let ssid = info?.ssid || '';

				let assoc = ubus.call('iwinfo', 'assoclist', {
					device: ifname
				});

				if (!assoc?.results)
					continue;

				for (let bss in assoc.results) {
					let mac = bss?.mac;

					if (!mac)
						continue;

					mac = uc(mac);

					seen_macs[mac] = true;

					let hostname = hints?.[mac]?.name || '';
					let ipv4 = hints?.[mac]?.ipaddrs?.[0] || '';
					let ipv6 = hints?.[mac]?.ip6addrs?.[0] || '';

					let existing = history[mac];

					history[mac] = {
						mac: mac,
						type: 'wifi',
						hostname: hostname,
						ipv4: ipv4,
						ipv6: ipv6,
						network: ssid,
						ifname: ifname,
						connected: true,
						signal: bss?.signal || 0,
						noise: bss?.noise || 0,
						first_seen: existing?.first_seen || now,
						last_seen: now
					};
				}
			}
		}
	}

	/*
	 * ETHERNET CLIENTS
	 */

	let neigh = get_ip_neigh();

	for (let mac in neigh) {
		if (seen_macs[mac])
			continue;

		let n = neigh[mac];

		if (!n.ifname)
			continue;

		/*
		 * 跳过 WAN
		 */

		if (n.ifname == 'eth0' ||
		    n.ifname == 'wan')
			continue;

		let hostname = hints?.[mac]?.name || '';

		let existing = history[mac];

		history[mac] = {
			mac: mac,
			type: 'ethernet',
			hostname: hostname,
			ipv4: n?.ipv4 || '',
			ipv6: n?.ipv6 || '',
			network: 'LAN',
			ifname: n.ifname,
			connected: true,
			signal: 0,
			noise: 0,
			first_seen: existing?.first_seen || now,
			last_seen: now
		};

		seen_macs[mac] = true;
	}

	/*
	 * OFFLINE CLIENTS
	 */

	for (let mac in history) {
		if (!seen_macs[mac])
			history[mac].connected = false;
	}

	ubus.disconnect();

	save_history(history);
}

mkdir(HISTORY_DIR);

let lock_fd = open(LOCK_FILE, 'w');

if (!lock_fd) {
	warn('Failed to open lock file\n');
	exit(1);
}

if (!lock_fd.lock('xn')) {
	warn('Another instance is already running\n');
	lock_fd.close();
	exit(1);
}

poll_stations();

lock_fd.lock('u');
lock_fd.close();
